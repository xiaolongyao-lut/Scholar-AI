{
  "schema_version": 1,
  "package_id": "lit-mcp-vision-auxiliary",
  "display_name": "视觉辅助",
  "description": "让智能研读能理解你上传的图片。它会把图片内容整理成中文说明，再交给主对话参考。",
  "transport": "stdio",
  "launch": {
    "command": "python",
    "args": ["-m", "lit_mcp_vision_auxiliary.server"],
    "cwd": "."
  },
  "config_fields": [
    {
      "id": "vision_provider",
      "label": "视觉服务",
      "env": "VISION_PROVIDER",
      "type": "select",
      "required": true,
      "default": "siliconflow",
      "description": "选择负责分析图片的服务。也可以选择自定义，用任何兼容的服务地址和模型名称。",
      "options": [
        { "value": "siliconflow", "label": "硅基流动" },
        { "value": "openai", "label": "OpenAI" },
        { "value": "anthropic", "label": "Anthropic" },
        { "value": "gemini", "label": "Google Gemini" },
        { "value": "custom", "label": "自定义 / 手动填写" }
      ]
    },
    {
      "id": "vision_base_url",
      "label": "自定义服务地址（可选）",
      "env": "VISION_BASE_URL",
      "type": "text",
      "required": false,
      "default": "",
      "description": "使用自定义服务、代理网关或非默认地址时填写；留空则使用所选服务的默认地址。"
    },
    {
      "id": "vision_model",
      "label": "图片理解模型",
      "env": "VISION_MODEL",
      "type": "text",
      "required": true,
      "default": "Qwen2-VL-7B-Instruct",
      "description": "填写支持图片输入的模型名称。不同服务的模型名称可能不同，可以按服务商文档手动填写。"
    },
    {
      "id": "max_note_chars",
      "label": "单张图片说明长度上限",
      "env": "MAX_NOTE_CHARS",
      "type": "number",
      "required": false,
      "default": "3200",
      "min": 400,
      "max": 12000,
      "step": 100,
      "description": "限制每张图片生成说明的最多字符数。默认 3200 适合较详细说明；图片很多或回答变慢时调小，想保留更多细节时调大。"
    }
  ],
  "required_credentials": [
    {
      "id": "vision_api_key",
      "label": "视觉服务访问凭证",
      "env": "VISION_API_KEY",
      "kind": "api_key",
      "provider_hints": ["siliconflow", "openai", "anthropic", "gemini", "custom"],
      "required": true,
      "description": "选择已保存的视觉服务凭证。也可以先到凭证管理新增任意兼容服务，再回到这里绑定。"
    }
  ],
  "expected_tools": [
    "analyze_images_batch",
    "vision.describe_image",
    "vision.extract_text"
  ],
  "capabilities": ["read"],
  "homepage": "https://github.com/anthropics/literature-assistant",
  "version": "0.1.0"
}
