      "page": 7,
      "bbox": [
        84.4,
        437.6,
        353.41,
        455.6
      ],
      "mentioned_figures": [],
      "mentioned_tables": [],
      "section_title": "Page Content"
    },
    {
      "chunk_id": "c0040",
      "text": ": Subtract 1. A 1 does not become a 6",
      "page": 7,
