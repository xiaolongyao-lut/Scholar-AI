# Keep these local by default; public commits should use explicit product paths.
/workspace_ai/
/workspace_ai/local_state/
/workspace_artifacts/
/workspace_references/
/workspace_tests/

# Workspace scratch areas.
/tests/
/workspace_tests/benchmarks/results/
/workspace_tests/diagnostics/
/workspace_tests/evaluation_data/BASELINE_METRICS.json
/workspace_tests/provider_proxy/
/workspace_tests/scratch/

