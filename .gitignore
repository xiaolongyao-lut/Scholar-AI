# are Literature Assistant installable packages; do not embed them in runtime code.
/literature_assistant/core/skills/importers/ui-ux-pro-max/

# Workspace runtime/generated artifacts.
# Keep these local by default; public commits should use explicit product paths.
/workspace_ai/
/workspace_ai/local_state/
/workspace_artifacts/
/workspace_references/
/workspace_tests/

# Workspace scratch areas. Public tests and release scripts may be promoted
