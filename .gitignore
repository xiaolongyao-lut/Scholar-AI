# Environment files and local secrets.
# Git patterns without "/" match a basename at any directory depth.
.env
.env.*
.envrc

# Root-only local instruction and agent configuration files.
# Leading "/" keeps these rules from hiding product/vendored subdirectories.
/AGENTS.md
/AI_WORKSPACE_GUIDE.md
/CLAUDE.md
/DEVELOPER_GUIDE.md
/GEMINI.md
/MEMORY.md
/OPEN_THREADS.md
/skill_sync_bridge.ps1

# Root-only local agent/editor state.
/.claude/
/.claude_squad/
/.continue/
/.copilot/
/.copilot-tracking/
/.oracle_phase6_eval/
/.cursor/
/.kilo/
/.squad/
/.squad-workstream
/.vite/
/.vscode/
/.vs/
/.idea/
/.config/
/.mcp.json
/.opencode/

# Root-only GitHub agent scaffolding; keep normal workflow files trackable.
/.github/
/.github/agents/
/.github/chatmodes/
/.github/copilot-instructions.md
/.github/hooks/
/.github/instructions/
/.github/prompts/
/.github/skills/
/.github/workflows/squad-*.yml
/.github/workflows/sync-squad-labels.yml

# Internal planning, review, and agent process documents.
# Public repository surface keeps root README/CHANGELOG/CONTRIBUTING/SECURITY only.
/docs/

# Python caches and test outputs.
__pycache__/
*.py[cod]
*.pyd
.pytest_cache/
.coverage
htmlcov/

# JavaScript/frontend outputs.
/package-lock.json
/frontend/node_modules/
/frontend/dist/
/frontend/.vite/
/frontend/out/
/frontend/tests/
/frontend/src/test/
/frontend/**/*.test.ts
/frontend/**/*.test.tsx
/frontend/**/*.test.mjs
/frontend/playwright.config.ts
/frontend/vite.config.e2e.ts
/frontend/.axe-linter.yml
/frontend/test-results/
/frontend/.rollback_snapshots/
/frontend/output/
/frontend/test_output.txt

# Local runtime roots and deprecated repo residue.
/output/
/.modular/
/legacy_archive/
/github/
/my-project/
/packaging/
/scripts/
/skills/
/tools/
/literature_assistant/core/skills/importers/ui-ux-pro-max/

