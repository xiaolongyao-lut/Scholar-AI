# Public source boundary: see SOURCE_RELEASE_POLICY.md before changing what
# belongs in GitHub release source archives.

# Environment files and local secrets.
# Git patterns without "/" match a basename at any directory depth.
.env
.env.*
.envrc
!/.env.example
!/frontend.env.example

# Root-only local instruction and agent configuration files.
# Leading "/" keeps these rules from hiding product/vendored subdirectories.
/AGENTS.md
/AI_WORKSPACE_GUIDE.md
/CLAUDE.md
/DEVELOPER_GUIDE.md
/GEMINI.md
/MEMORY.md
/OPEN_THREADS.md
/skill_sync_bridge.ps1

# Root-only local agent/editor state.
/.claude/
/.claude_squad/
/.continue/
/.copilot/
/.copilot-tracking/
/.oracle_phase6_eval/
/.cursor/
/.kilo/
/.squad/
/.squad-workstream
/.vite/
/.vscode/
/.vs/
/.idea/
/.config/
/.mcp.json
/.opencode/

# Root-only runtime diagnostics / probe outputs. These files contain key
# fingerprints, API endpoint health, browser session traces, etc. Never
# commit them — they leak credentials and pollute git status between runs.
/.connectivity_results.json
/.team_api_health.json
/.playwright-cli/

# Root-only ad-hoc audit notes that the team treats as local-only until they
# are explicitly converted into product docs under docs/plans/.
/SECURITY_AUDIT_*.md
/SECURITY_AUDIT_REPORT_*.md
/CHANGELOG.md

# Root-only GitHub files are ignored by default because this workspace contains
# private agent scaffolding. Public CI workflows may be promoted explicitly under
# SOURCE_RELEASE_POLICY.md.
/.github/
!/.github/
/.github/*
!/.github/workflows/
/.github/workflows/*
!/.github/workflows/ci.yml
!/.github/workflows/online-smoke.yml
/.github/agents/
/.github/chatmodes/
/.github/copilot-instructions.md
/.github/hooks/
/.github/instructions/
/.github/prompts/
/.github/skills/
/.github/workflows/squad-*.yml
/.github/workflows/sync-squad-labels.yml

# Internal planning, review, and agent process documents. Public docs may be
# promoted explicitly only after plan/runbook/private evidence review.
/docs/*
!/docs/API_CONFIGURATION.md
!/docs/LOCAL_RERANK_MODELS.md
!/docs/MCP_SECURITY_ISOLATION.md
!/docs/OPTIONAL_ADDONS.md
!/docs/claude-codex-toolbox.md
!/docs/claude-codex-toolbox.en.md
!/docs/rag-evidence-architecture.md
!/docs/rag-evidence-architecture.en.md
!/docs/local-rerank-fallback-models.md

# Public installable Literature Assistant extension packages.
# Commit only packages that the app can scan/install directly:
#   - extension_packages/skills/<package>/SKILL.md
#   - extension_packages/mcp/<package>/literature-mcp.json or lit-mcp.json
# Never commit user-filled configs, local credentials, installed runtime state,
# generic agent package directories, plugin bundles, unrelated tool ecosystems,
# or package-local caches. MCP package manifests may declare credential slots
# but must not include filled API keys/tokens or machine-local credential ids.
/extension_packages/**/.env
/extension_packages/**/.env.*
/extension_packages/**/.envrc
/extension_packages/**/secrets.*
/extension_packages/**/credentials.*
/extension_packages/**/runtime_mcp_servers.json
/extension_packages/**/runtime_credentials.json
/extension_packages/**/install_record.json
/extension_packages/**/*credential*.json
/extension_packages/**/*token*.json
/extension_packages/**/*secret*.json
/extension_packages/**/*api_key*.json
/extension_packages/**/*.key
/extension_packages/**/*.pem
/extension_packages/**/*.p12
/extension_packages/**/*.pfx
/extension_packages/**/*.sqlite
/extension_packages/**/*.sqlite3
/extension_packages/**/*.db
/extension_packages/**/*.db-shm
/extension_packages/**/*.db-wal
/extension_packages/**/__pycache__/
/extension_packages/**/*.py[cod]
/extension_packages/**/node_modules/
/extension_packages/**/dist/
/extension_packages/**/build/
/extension_packages/**/.vite/
/extension_packages/**/.cache/
/extension_packages/**/.turbo/
/extension_packages/**/.pytest_cache/
/extension_packages/**/.claude/
/extension_packages/**/.claude-plugin/
/extension_packages/**/.codex/
/extension_packages/**/.agents/
/extension_packages/**/.github/

