# Scholar AI environment template
#
# Copy this file to `.env` only when you run from source or need repeatable
# test configuration. Normal desktop users should configure providers in
# Settings instead.
#
# Never commit `.env`.


# ---------------------------------------------------------------------------
# Embedding API
# ---------------------------------------------------------------------------

EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=


# ---------------------------------------------------------------------------
# Rerank API
# ---------------------------------------------------------------------------

RERANK_API_KEY=
RERANK_BASE_URL=https://api.siliconflow.cn/v1/rerank
RERANK_MODEL=


# ---------------------------------------------------------------------------
# LLM / SmartRead API
# ---------------------------------------------------------------------------

CHAT_API_KEY=
CHAT_BASE_URL=
CHAT_MODEL=
