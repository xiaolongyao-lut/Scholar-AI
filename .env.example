# =============================================================================
# AI API Configuration Template
# Copy this file to .env and fill in your real API keys.
# NEVER commit .env to version control (already in .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# SiliconFlow — Embedding & Reranker
# https://siliconflow.cn/
# Used by: chunk_vector_store.py, r_layer_hybrid_retriever.py, reranker_client.py
# -----------------------------------------------------------------------------
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# Optional: separate key for reranker (falls back to SILICONFLOW_API_KEY if unset)
SILICONFLOW_RERANK_API_KEY=your_siliconflow_rerank_api_key_here

# Optional overrides (defaults shown)
# SILICONFLOW_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
# SILICONFLOW_RERANK_BASE_URL=https://api.siliconflow.cn/v1/rerank
# SILICONFLOW_RERANK_MODEL=Qwen/Qwen3-Reranker-8B

# -----------------------------------------------------------------------------
# Volcano ARK (ByteDance) — LLM for query expansion / contextual chunking
# https://ark.cn-beijing.volces.com/
# Used by: query_expander.py, contextual_chunker.py, layers/ai_adapter.py
# -----------------------------------------------------------------------------
ARK_API_KEY=your_ark_api_key_here

# Base URL for the ARK completions endpoint
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Your deployed model endpoint ID (format: ep-XXXXXXXX-XXXX)
ARK_MODEL=ep-20260414011719-8x7s4

# Alias accepted by query_expander.py (same key as ARK_API_KEY)
# VOLCANO_API_KEY=your_ark_api_key_here
