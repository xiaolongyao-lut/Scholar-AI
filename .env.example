# Scholar AI environment template
#
# Copy this file to `.env`, then fill in your own keys.
# Never commit `.env`.
#
# The app can also store provider settings from the Settings page. This file is
# mainly for source runs, CI, and repeatable local testing.


# ---------------------------------------------------------------------------
# Embedding and rerank provider
# ---------------------------------------------------------------------------

# A single SiliconFlow key can be reused by embedding and rerank.
SILICONFLOW_API_KEY=

# Optional: use separate keys when your provider account separates products.
# SILICONFLOW_EMBEDDING_API_KEY=
# SILICONFLOW_RERANK_API_KEY=

# Optional: override official endpoints only when the provider changes them.
# SILICONFLOW_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# SILICONFLOW_RERANK_BASE_URL=https://api.siliconflow.cn/v1/rerank

# Optional: DashScope rerank.
# DASHSCOPE_RERANK_API_KEY=
# DASHSCOPE_RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank


# ---------------------------------------------------------------------------
# Chat / LLM provider
# ---------------------------------------------------------------------------

# OpenAI-compatible chat endpoint. Fill the model value with the deployment or
# model name configured in your provider account.
CHAT_PROVIDER=
CHAT_API_KEY=
CHAT_BASE_URL=
CHAT_MODEL=

# Optional: Volcengine ARK / Doubao-compatible chat endpoint.
# ARK_API_KEY=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL=


# ---------------------------------------------------------------------------
# Local source folders
# ---------------------------------------------------------------------------

# Separate multiple folders with `;` or `,`.
# LITERATURE_SOURCE_PATHS=C:\path\to\papers;C:\path\to\notes


# ---------------------------------------------------------------------------
# VPN / proxy DNS compatibility
# ---------------------------------------------------------------------------

# Some VPN clients use fake-IP DNS ranges such as 198.18.0.0/15. Keep this off
# unless official provider requests are blocked with `dns_resolved_to_unsafe_ip`
# while the VPN is enabled.
# LITASSIST_ALLOW_PROXY_FAKE_IP_FOR_OFFICIAL_PROVIDERS=1
# LITASSIST_PROXY_FAKE_IP_CIDRS=198.18.0.0/15


# ---------------------------------------------------------------------------
# Optional source-only local extensions
# ---------------------------------------------------------------------------

# Windows installer builds do not include local inference modules. These options
# are for source runs where the extra Python packages and model weights are
# installed by the developer.

# PDF parser: default is PyMuPDF. Set only after installing marker-pdf.
# LITASSIST_PDF_PARSER=marker

# Local rerank / embedding downloads are disabled by default. Device selection
# is automatic; set LOCAL_*_DEVICE only when you need to force a backend.
# LOCAL_RERANK_ALLOW_DOWNLOAD=1
# LOCAL_RERANK_DEVICE=
# LOCAL_EMBEDDING_ALLOW_DOWNLOAD=1
# LOCAL_EMBEDDING_DEVICE=
