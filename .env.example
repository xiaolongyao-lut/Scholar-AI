# Scholar AI environment template
#
# Copy this file to `.env`, then fill in your own keys.
# Never commit `.env`.
#
# Most settings can also be configured in the app UI. Environment variables are
# useful for source builds, CI, and repeatable local testing.


# ---------------------------------------------------------------------------
# Recommended: SiliconFlow for embedding and rerank
# ---------------------------------------------------------------------------

# One SiliconFlow key can be used for both embedding and rerank.
SILICONFLOW_API_KEY=

# Optional: use separate keys for embedding and rerank.
# These take precedence over SILICONFLOW_API_KEY when present.
# SILICONFLOW_EMBEDDING_API_KEY=
# SILICONFLOW_RERANK_API_KEY=

# Optional: override SiliconFlow defaults.
# SILICONFLOW_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
# SILICONFLOW_RERANK_BASE_URL=https://api.siliconflow.cn/v1/rerank
# SILICONFLOW_RERANK_MODEL=qwen3-rerank


# ---------------------------------------------------------------------------
# Optional: DashScope rerank
# ---------------------------------------------------------------------------

# DASHSCOPE_RERANK_API_KEY=
# DASHSCOPE_RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
# DASHSCOPE_RERANK_MODEL=qwen3-rerank


# ---------------------------------------------------------------------------
# Chat / LLM
# ---------------------------------------------------------------------------

# OpenAI-compatible chat endpoint. The app also supports configuring this in UI.
CHAT_PROVIDER=OpenAI
CHAT_API_KEY=
CHAT_BASE_URL=https://api.example.com/v1
CHAT_MODEL=your-chat-model

# Optional ARK / Doubao-compatible configuration.
# ARK_API_KEY=
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# ARK_MODEL=ep-your-deployed-endpoint-id


# ---------------------------------------------------------------------------
# Local source folders for intelligent chat
# ---------------------------------------------------------------------------

# Separate multiple folders with `;` or `,`.
# LITERATURE_SOURCE_PATHS=C:\path\to\papers;C:\path\to\notes


# ---------------------------------------------------------------------------
# VPN / proxy DNS compatibility
# ---------------------------------------------------------------------------

# Some VPN clients use fake-IP DNS ranges such as 198.18.0.0/15. Keep this off
# unless official provider requests are blocked with `dns_resolved_to_unsafe_ip`
# while the VPN is enabled.
# LITASSIST_ALLOW_PROXY_FAKE_IP_FOR_OFFICIAL_PROVIDERS=1
# LITASSIST_PROXY_FAKE_IP_CIDRS=198.18.0.0/15


# ---------------------------------------------------------------------------
# Optional source-only local acceleration
# ---------------------------------------------------------------------------

# Windows installer builds do not include local inference modules. These options
# are for source builds where the extra Python packages and model weights are
# installed by the developer.

# PDF parser: default is PyMuPDF. Set to `marker` only after installing
# marker-pdf in the source environment.
# LITASSIST_PDF_PARSER=marker

# Local rerank / embedding controls.
# LOCAL_RERANK_ALLOW_DOWNLOAD=1
# LOCAL_RERANK_DEVICE=cpu
# LOCAL_EMBEDDING_ALLOW_DOWNLOAD=1
# LOCAL_EMBEDDING_DEVICE=cpu
