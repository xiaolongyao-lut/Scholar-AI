# =============================================================================
# AI API Configuration Template
# Copy this file to .env and fill in your real API keys.
# NEVER commit .env to version control (already in .gitignore).
# Provider-specific variables take precedence over legacy generic RERANK_* values.
# =============================================================================

# -----------------------------------------------------------------------------
# SiliconFlow — Embedding & Reranker
# https://siliconflow.cn/
# Used by: chunk_vector_store.py, r_layer_hybrid_retriever.py, reranker_client.py
# -----------------------------------------------------------------------------
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# Optional: separate key for reranker (falls back to SILICONFLOW_API_KEY if unset)
SILICONFLOW_RERANK_API_KEY=your_siliconflow_rerank_api_key_here

# Optional overrides (defaults shown)
# SILICONFLOW_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
# SILICONFLOW_RERANK_BASE_URL=https://api.siliconflow.cn/v1/rerank
# SILICONFLOW_RERANK_MODEL=qwen3-rerank

# -----------------------------------------------------------------------------
# DashScope — qwen3-rerank
# https://www.alibabacloud.com/help/en/model-studio/text-rerank-api
# Used by: reranker_client.py, layers/r_layer_hybrid_retriever.py
# -----------------------------------------------------------------------------
# DASHSCOPE_API_KEY=your_dashscope_api_key_here
# DASHSCOPE_RERANK_API_KEY=your_dashscope_rerank_api_key_here
# DASHSCOPE_RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank
# DASHSCOPE_RERANK_MODEL=qwen3-rerank

# -----------------------------------------------------------------------------
# Volcano ARK (ByteDance) — LLM for query expansion / contextual chunking
# https://ark.cn-beijing.volces.com/
# Used by: query_expander.py, contextual_chunker.py, layers/ai_adapter.py
# -----------------------------------------------------------------------------
ARK_API_KEY=your_ark_api_key_here

# Base URL for the ARK completions endpoint
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Your deployed model endpoint ID (format: ep-XXXXXXXX-XXXX)
ARK_MODEL=ep-20260414011719-8x7s4

# Alias accepted by query_expander.py (same key as ARK_API_KEY)
# VOLCANO_API_KEY=your_ark_api_key_here

# Optional OpenAI-compatible fallback (for local proxies or compatible gateways)
# OPENAI_API_KEY=your_openai_compatible_key_here
# OPENAI_BASE_URL=http://127.0.0.1:8000/v1
# OPENAI_MODEL=your-openai-compatible-model

# ---------------------------------------------------------------------------
# Intelligent Chat compatibility API (/api/chat)
# Used by: frontend IntelligentChat page.
# Keep source folders local and readable; separate multiple paths with ; or ,.
# ---------------------------------------------------------------------------
# LITERATURE_SOURCE_PATHS=workspace_references/project_notes;workspace_tests/evaluation_data
# CHAT_PROVIDER=OpenAI
# CHAT_API_KEY=your_chat_api_key_here
# CHAT_BASE_URL=https://api.example.com/v1
# CHAT_MODEL=your-chat-model
# CHAT_MAX_TOKENS=2048
# INTELLIGENT_CHAT_RAGWORKFLOW_ENABLED=0
# INTELLIGENT_CHAT_DAILY_CALL_CAP=200
# INTELLIGENT_CHAT_DAILY_BUDGET_USD=5

# -----------------------------------------------------------------------------
# Global AI Cost Profile (applies to literature-assistant AI calls)
# balanced  : 默认平衡模式
# aggressive: 强降本（禁用高成本 multi-query / HyDE / contextual-summary）
# quality   : 质量优先（保留所有增强链路）
# -----------------------------------------------------------------------------
LITERATURE_AI_COST_PROFILE=balanced

# Rerank result cache (process-local, helps reduce repeated API spend)
RERANK_CACHE_ENABLED=1
RERANK_CACHE_VERSION=v1

# Runtime RAG rerank is default-off after current canary evidence.
# Set to 1 only for guarded local canary runs; eval scripts still use their own
# explicit --no-rerank / use_rerank switches.
# RAG_RUNTIME_RERANK_ENABLED=0

# Rerank daily budget guard
# - hard cap by call count
# - hard cap by estimated tokens
# - USD is telemetry-only soft warning (no fallback)
# RERANK_DAILY_CALL_CAP=5000
# RERANK_DAILY_TOKEN_CAP=1500000
# RERANK_DAILY_BUDGET_USD=5
