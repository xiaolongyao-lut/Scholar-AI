# ==========================
# 前端环境变量模板（可分享）
# ==========================
# 用法：复制到 frontend/.env.local，再填写实际值
# 模型供应商密钥必须放在后端凭据中心，不要写入 Vite 前端环境变量。

# 1) 前端请求你的后端
VITE_API_BASE_URL=

# 2) 可选开关（可留空）
VITE_FLAG_RESEARCH_WORKBENCH=
VITE_SMART_READ_DEBUG=

# 严禁放入前端：OPENAI_API_KEY / RERANK_API_KEY / EMBEDDING_API_KEY / VITE_*API_KEY
