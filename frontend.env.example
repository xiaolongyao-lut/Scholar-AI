# ==========================
# 前端队员 API 填写模板（可分享）
# ==========================
# 用法：复制到 frontend/.env.local，再填写实际值
# 默认回退顺序：主路第三方 -> 后端默认路数
# 仅当你显式填写 Copilot 的 BASE_URL / MODEL / API_KEY 时，才会启用 Copilot 中间回退

# 1) 前端请求你的后端（推荐）
VITE_API_BASE_URL=
VITE_FRONTEND_APP_TOKEN=

# 2) 主路第三方（BASE_URL / API_KEY / MODEL，可选）
# 注意：只给前端“低权限专用 key”，不要给主账号高权限密钥。
VITE_BASE_URL=https://api.example.com/v1
VITE_API_KEY=your_low_privilege_frontend_api_key_here
VITE_MODEL=your-frontend-model

# 3) Copilot 回退（可选，不填则默认关闭）
# 不知道 Copilot key 就留空，系统会直接回退后端默认路数
VITE_COPILOT_PROVIDER=Copilot
VITE_COPILOT_BASE_URL=
VITE_COPILOT_API_KEY=
VITE_COPILOT_MODEL=

# 4) 可选开关（可留空）
VITE_ENABLE_CONTEXTUAL=
VITE_ENABLE_SAMPLING_PANEL=

# 严禁放入前端：OPENAI_API_KEY / RERANK_API_KEY / EMBEDDING_API_KEY 等高权限密钥
