{
  "name": "modular-pipeline-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run generate:openapi:if-needed",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:e2e": "npx playwright test",
    "test:e2e:agent-workspace": "npx playwright test --config playwright.agent-workspace.config.ts",
    "test:all": "vitest run && npx playwright test",
    "generate:openapi:schema": "node ./scripts/generate-openapi-schema.mjs --output openapi/modular-pipeline-openapi.json",
    "generate:openapi:types": "openapi-typescript ./openapi/modular-pipeline-openapi.json -o ./src/generated/openapi.ts",
    "generate:openapi": "npm run generate:openapi:schema && npm run generate:openapi:types",
    "generate:openapi:if-needed": "node ./scripts/generate-openapi-if-needed.mjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@tiptap/extension-color": "^3.22.5",
    "@tiptap/extension-font-family": "^3.22.5",
    "@tiptap/extension-heading": "^3.22.5",
    "@tiptap/extension-highlight": "^3.22.5",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/extension-subscript": "^3.22.5",
    "@tiptap/extension-superscript": "^3.22.5",
    "@tiptap/extension-table": "^3.22.5",
    "@tiptap/extension-table-cell": "^3.22.5",
    "@tiptap/extension-table-header": "^3.22.5",
    "@tiptap/extension-table-row": "^3.22.5",
    "@tiptap/extension-text-align": "^3.22.5",
    "@tiptap/extension-text-style": "^3.22.5",
    "@tiptap/extension-underline": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@xyflow/react": "^12.10.2",
    "axios": "^1.6.7",
    "citeproc": "^2.4.63",
    "clsx": "^2.1.0",
    "docx": "^9.6.1",
    "dompurify": "^3.4.8",
    "file-saver": "^2.0.5",
    "framer-motion": "^11.0.8",
    "lucide-react": "^0.344.0",
    "pdfjs-dist": "5.4.296",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "react-router-dom": "^6.22.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.2.1",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^15.0.7",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.61",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^24.1.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^5.1.4",
    "vitest": "^1.6.0"
  }
}
