# 前端队员本地填写（复制为 .env.local）

# 推荐：前端走你自己的后端
VITE_API_BASE_URL=
VITE_FRONTEND_APP_TOKEN=

# 按你习惯的三元组（可选）
VITE_BASE_URL=
VITE_API_KEY=
VITE_MODEL=

# Copilot 回退（可选，不填则默认关闭）
VITE_COPILOT_PROVIDER=Copilot
VITE_COPILOT_BASE_URL=
VITE_COPILOT_API_KEY=
VITE_COPILOT_MODEL=

# 功能开关（可留空）
VITE_ENABLE_CONTEXTUAL=
VITE_ENABLE_SAMPLING_PANEL=

# 联不通回退说明：默认直接回退后端当前默认路数；仅当 Copilot 三项（BASE_URL/MODEL/API_KEY）都填写时，才先回退 Copilot。
